body:             |
  bb.0 (%ir-block.0):
    successors: %bb.2(0x80000000)
  
    %29:gpr16 = LDI8_PSEUDO 64
    %28:gpr16 = DATA_ADDR_PSEUDO @A
    JMP_PSEUDO %bb.2
  
  bb.1 (%ir-block.1):
    successors: %bb.4(0x80000000)
  
    %35:gpr16 = LDI8_PSEUDO 64
    SYS_DEBUG_BREAK_PSEUDO
    %36:gpr16 = LDI8_PSEUDO 0
    STACK_STORE16_PSEUDO %stack.0, 0, %36 :: (store (s16) into %stack.0, align 1)
    %37:gpr16 = LDI8_PSEUDO 1
    STACK_STORE16_PSEUDO %stack.1, 0, %37 :: (store (s16) into %stack.1, align 1)
    JMP_PSEUDO %bb.4
  
  bb.2 (%ir-block.2):
    successors: %bb.1(0x04000000), %bb.2(0x7c000000)
  
    %18:gpr32 = ZEXT16_32_PSEUDO %29
    STORE32_PSEUDO %28, %18 :: (store (s32) into %ir.3, align 1, !tbaa !6)
    %28:gpr16 = ADDIS8_PSEUDO %28, 4
    %29:gpr16 = nsw DEC16_PSEUDO %29
    TST16_PSEUDO %29, implicit-def $cc
    BR_CC_PSEUDO %bb.1, 0, implicit $cc
    JMP_PSEUDO %bb.2
  
  bb.3 (%ir-block.9):
    successors: %bb.4(0x783e0f0f), %bb.8(0x07c1f0f1)
  
    %26:gpr16 = COPY %35
    %26:gpr16 = ZEXT8_PSEUDO %26
    CMPIS8_PSEUDO %26, 2, implicit-def $cc
    BR_CC_PSEUDO %bb.8, 2, implicit $cc
    JMP_PSEUDO %bb.4
  
  bb.4 (%ir-block.11):
    successors: %bb.5(0x80000000)
  
    %33:gpr16 = DATA_ADDR_PSEUDO @A + 4
    %35:gpr16 = ZEXT8_PSEUDO %35
    %35:gpr16 = nsw DEC16_PSEUDO %35
    %31:gpr16 = COPY %35
    %32:gpr16 = STACK_LOAD16_PSEUDO %stack.1, 0 :: (load (s16) from %stack.1, align 1)
    %35:gpr16 = STACK_LOAD16_PSEUDO %stack.0, 0 :: (load (s16) from %stack.0, align 1)
  
  bb.5 (%ir-block.15):
    successors: %bb.6(0x40000000), %bb.7(0x40000000)
  
    %11:gpr32 = LOAD32_PSEUDO %33 :: (load (s32) from %ir.18, align 1, !tbaa !6)
    %24:gpr16 = COPY %33
    %24:gpr16 = ADDIS8_PSEUDO %24, -4
    %10:gpr32 = LOAD32_PSEUDO %24 :: (load (s32) from %ir.20, align 1, !tbaa !6)
    CMP32_PSEUDO %11, %10, implicit-def $cc
    BR_CC_PSEUDO %bb.7, 5, implicit $cc
    JMP_PSEUDO %bb.6
  
  bb.6 (%ir-block.24):
    successors: %bb.7(0x80000000)
  
    STORE32_PSEUDO %33, %10 :: (store (s32) into %ir.18, align 1, !tbaa !6)
    %25:gpr16 = COPY %33
    %25:gpr16 = ADDIS8_PSEUDO %25, -4
    STORE32_PSEUDO %25, %11 :: (store (s32) into %ir.25, align 1, !tbaa !6)
    %35:gpr16 = COPY %32
  
  bb.7 (%ir-block.26):
    successors: %bb.3(0x04000000), %bb.5(0x7c000000)
  
    %32:gpr16 = INC16_PSEUDO %32
    %33:gpr16 = ADDIS8_PSEUDO %33, 4
    %31:gpr16 = DEC16_PSEUDO %31
    TST16_PSEUDO %31, implicit-def $cc
    BR_CC_PSEUDO %bb.3, 0, implicit $cc
    JMP_PSEUDO %bb.5
  
  bb.8 (%ir-block.32):
    SYS_DEBUG_BREAK_PSEUDO
    %27:gpr16 = LDI8_PSEUDO 0
    $r4 = COPY %27
    RET_PSEUDO implicit-def dead $sp, implicit $sp, implicit $r4
...
