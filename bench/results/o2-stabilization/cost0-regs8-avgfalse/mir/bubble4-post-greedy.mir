--- |
  ; ModuleID = 'C:\Users\Brown\Documents\GitHub\avm\bench\c\bubble4.c'
  source_filename = "C:\\Users\\Brown\\Documents\\GitHub\\avm\\bench\\c\\bubble4.c"
  target datalayout = "e-m:e-p:16:8-p1:24:8-i8:8-i16:8-i32:8-i64:8-f16:8-f32:8-n8:16-S8-P1-G0-A0"
  target triple = "avm-unknown-arduboyfx"
  
  @A = dso_local local_unnamed_addr global [64 x i32] zeroinitializer, align 1
  
  ; Function Attrs: nofree norecurse nounwind
  define dso_local noundef i16 @avm_test_main() local_unnamed_addr addrspace(1) #0 {
    br label %2
  
  1:                                                ; preds = %2
    tail call addrspace(1) void @llvm.avm.debug.break()
    br label %11
  
  2:                                                ; preds = %0, %2
    %3 = phi ptr [ @A, %0 ], [ %7, %2 ]
    %4 = phi i16 [ 64, %0 ], [ %6, %2 ]
    %5 = zext nneg i16 %4 to i32
    store i32 %5, ptr %3, align 1, !tbaa !6
    %6 = add nsw i16 %4, -1
    %7 = getelementptr i8, ptr %3, i16 4
    %8 = icmp eq i16 %6, 0
    br i1 %8, label %1, label %2, !llvm.loop !8
  
  9:                                                ; preds = %26
    %10 = icmp ugt i8 %27, 1
    br i1 %10, label %11, label %32, !llvm.loop !10
  
  11:                                               ; preds = %1, %9
    %12 = phi i8 [ 64, %1 ], [ %27, %9 ]
    %13 = zext i8 %12 to i16
    %14 = add nsw i16 %13, -1
    br label %15
  
  15:                                               ; preds = %11, %26
    %16 = phi i16 [ %14, %11 ], [ %30, %26 ]
    %17 = phi i8 [ 1, %11 ], [ %29, %26 ]
    %18 = phi ptr [ getelementptr inbounds nuw (i8, ptr @A, i16 4), %11 ], [ %28, %26 ]
    %19 = phi i8 [ 0, %11 ], [ %27, %26 ]
    %20 = getelementptr i8, ptr %18, i16 -4
    %21 = load i32, ptr %20, align 1, !tbaa !6
    %22 = load i32, ptr %18, align 1, !tbaa !6
    %23 = icmp sgt i32 %21, %22
    br i1 %23, label %24, label %26
  
  24:                                               ; preds = %15
    %25 = getelementptr i8, ptr %18, i16 -4
    store i32 %22, ptr %25, align 1, !tbaa !6
    store i32 %21, ptr %18, align 1, !tbaa !6
    br label %26
  
  26:                                               ; preds = %24, %15
    %27 = phi i8 [ %17, %24 ], [ %19, %15 ]
    %28 = getelementptr i8, ptr %18, i16 4
    %29 = add i8 %17, 1
    %30 = add i16 %16, -1
    %31 = icmp eq i16 %30, 0
    br i1 %31, label %9, label %15, !llvm.loop !11
  
  32:                                               ; preds = %9
    tail call addrspace(1) void @llvm.avm.debug.break()
    ret i16 0
  }
  
  ; Function Attrs: mustprogress nocallback nofree nounwind willreturn
  declare void @llvm.avm.debug.break() addrspace(1) #1
  
  attributes #0 = { nofree norecurse nounwind "no-builtins" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="avm1" "tune-cpu"="avm-interpreter-32u4-v1" }
  attributes #1 = { mustprogress nocallback nofree nounwind willreturn }
  
  !llvm.module.flags = !{!0}
  !llvm.ident = !{!1}
  !llvm.errno.tbaa = !{!2}
  
  !0 = !{i32 1, !"wchar_size", i32 2}
  !1 = !{!"clang version 22.1.8 (https://github.com/tiberiusbrown/llvm-project.git bfb537da7b0898514c500f193b67bbeaec224903)"}
  !2 = !{!3, !3, i64 0}
  !3 = !{!"int", !4, i64 0}
  !4 = !{!"omnipotent char", !5, i64 0}
  !5 = !{!"Simple C/C++ TBAA"}
  !6 = !{!7, !7, i64 0}
  !7 = !{!"long", !4, i64 0}
  !8 = distinct !{!8, !9}
  !9 = !{!"llvm.loop.mustprogress"}
  !10 = distinct !{!10, !9}
  !11 = distinct !{!11, !9}
...
