    $r4 = DATA_ADDR_PSEUDO @struct_result
    STORE32_PSEUDO killed $r4, killed $r6r7 :: (volatile store (s32) into @struct_result, align 1, !tbaa !14)
    SYS_DEBUG_BREAK_PSEUDO
    $r4 = LDI8_PSEUDO 0
    RET_PSEUDO implicit-def dead $sp, implicit $sp, implicit $r4
  
  bb.5 (%ir-block.24):
    successors: %bb.4(0x04000000), %bb.3(0x7c000000)
    liveins: $r6r7
  
    $r5 = STACK_LOAD16_PSEUDO %stack.0, 0 :: (load (s16) from %stack.0, align 1)
    $r5 = INC16_PSEUDO killed $r5
    $r4 = COPY $r5
    $r4 = ZEXT8_PSEUDO killed $r4
    CMPIS8_PSEUDO killed $r4, 16, implicit-def $cc
    BR_CC_PSEUDO %bb.4, 0, implicit $cc
    JMP_PSEUDO %bb.3
  
  bb.6 (%ir-block.27):
    successors: %bb.5(0x04000000), %bb.6(0x7c000000)
    liveins: $r3, $r4, $r6r7
  
    STACK_STORE16_PSEUDO %stack.4, 0, killed $r4 :: (store (s16) into %stack.4, align 1)
    $r2 = LOAD8U_PSEUDO $r3 :: (load (s8) from %ir.29, !tbaa !16)
    $r2 = SEXT8_PSEUDO killed $r2
    $r0 = LOAD16_DISP_PSEUDO $r3, -3 :: (load (s16) from %ir.33, align 1, !tbaa !2)
    $r2 = ADD16_PSEUDO killed $r2, $r0
    $r0r1 = ZEXT16_32_PSEUDO killed $r0
    STACK_STORE32_PSEUDO %stack.3, 0, killed $r0r1 :: (store (s32) into %stack.3, align 1)
    $r0 = COPY $r3
    $r0 = ADDIS8_PSEUDO killed $r0, -7
    $r4r5 = LOAD32_PSEUDO killed $r0 :: (load (s32) from %ir.31, align 1, !tbaa !14)
    $r0r1 = STACK_LOAD32_PSEUDO %stack.3, 0 :: (load (s32) from %stack.3, align 1)
    $r4r5 = ADD32_PSEUDO killed $r4r5, killed $r0r1
    $r0r1 = COPY killed $r4r5
    $r6r7 = ADD32_PSEUDO killed $r6r7, $r0r1
    $r4r5 = ZEXT16_32_PSEUDO killed $r2
    $r4r5 = XOR32_PSEUDO killed $r4r5, killed $r6r7
    $r6 = LOAD8U_DISP_PSEUDO $r3, -1 :: (load (s8) from %ir.35, !tbaa !16)
    $r6 = XOR16_PSEUDO killed $r6, $r0, implicit killed $r0r1
    $r0r1 = ZEXT16_32_PSEUDO killed $r6
    $r6r7 = LDI32_PSEUDO 255, 0
