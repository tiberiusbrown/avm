    $r6r7 = ADD32_PSEUDO killed $r6r7, killed $r4r5
    $r4 = STACK_LOAD16_PSEUDO %stack.4, 0 :: (load (s16) from %stack.4, align 1)
    $r3 = ADDIS8_PSEUDO killed $r3, 8
    $r4 = nsw DEC16_PSEUDO killed $r4
    TST16_PSEUDO $r4, implicit-def $cc
