--- |
  ; ModuleID = 'C:\Users\Brown\Documents\GitHub\avm\bench\c\struct_copy.c'
  source_filename = "C:\\Users\\Brown\\Documents\\GitHub\\avm\\bench\\c\\struct_copy.c"
  target datalayout = "e-m:e-p:16:8-p1:24:8-i8:8-i16:8-i32:8-i64:8-f16:8-f32:8-n8:16-S8-P1-G0-A0"
  target triple = "avm-unknown-arduboyfx"
  
  %struct.particle = type { i32, i16, i8, i8 }
  
  @input_particles = internal unnamed_addr global [24 x %struct.particle] zeroinitializer, align 1
  @struct_result = internal global i32 0, align 1
  
  ; Function Attrs: nofree norecurse nounwind
  define dso_local noundef i16 @avm_test_main() local_unnamed_addr addrspace(1) #0 {
    br label %2
  
  1:                                                ; preds = %2
    tail call addrspace(1) void @llvm.avm.debug.break()
    br label %20
  
  2:                                                ; preds = %0, %2
    %3 = phi ptr [ getelementptr inbounds nuw (i8, ptr @input_particles, i16 7), %0 ], [ %18, %2 ]
    %4 = phi i16 [ 5, %0 ], [ %17, %2 ]
    %5 = phi i8 [ -12, %0 ], [ %16, %2 ]
    %6 = phi i16 [ 0, %0 ], [ %15, %2 ]
    %7 = zext nneg i16 %6 to i32
    %8 = mul nuw nsw i32 %7, 66051
    %9 = add nuw nsw i32 %8, 65536
    %10 = getelementptr i8, ptr %3, i16 -7
    store i32 %9, ptr %10, align 1, !tbaa !6
    %11 = getelementptr i8, ptr %3, i16 -3
    store i16 %4, ptr %11, align 1, !tbaa !9
    %12 = add i8 %5, 12
    %13 = xor i8 %12, 90
    %14 = getelementptr i8, ptr %3, i16 -1
    store i8 %13, ptr %14, align 1, !tbaa !10
    store i8 %5, ptr %3, align 1, !tbaa !11
    %15 = add nuw nsw i16 %6, 1
    %16 = add nsw i8 %5, 1
    %17 = add nuw nsw i16 %4, 73
    %18 = getelementptr i8, ptr %3, i16 8
    %19 = icmp eq i16 %15, 24
    br i1 %19, label %1, label %2, !llvm.loop !12
  
  20:                                               ; preds = %1, %24
    %21 = phi i32 [ 0, %1 ], [ %48, %24 ]
    %22 = phi i8 [ 0, %1 ], [ %25, %24 ]
    br label %27
  
  23:                                               ; preds = %24
    store volatile i32 %48, ptr @struct_result, align 1, !tbaa !14
    tail call addrspace(1) void @llvm.avm.debug.break()
    ret i16 0
  
  24:                                               ; preds = %27
    %25 = add nuw nsw i8 %22, 1
    %26 = icmp eq i8 %25, 16
    br i1 %26, label %23, label %20, !llvm.loop !15
  
  27:                                               ; preds = %20, %27
    %28 = phi i16 [ 24, %20 ], [ %50, %27 ]
    %29 = phi ptr [ getelementptr inbounds nuw (i8, ptr @input_particles, i16 7), %20 ], [ %49, %27 ]
    %30 = phi i32 [ %21, %20 ], [ %48, %27 ]
    %31 = getelementptr i8, ptr %29, i16 -7
    %32 = load i32, ptr %31, align 1, !tbaa !14
    %33 = getelementptr i8, ptr %29, i16 -3
    %34 = load i16, ptr %33, align 1, !tbaa !2
    %35 = getelementptr i8, ptr %29, i16 -1
    %36 = load i8, ptr %35, align 1, !tbaa !16
    %37 = load i8, ptr %29, align 1, !tbaa !16
    %38 = zext i16 %34 to i32
    %39 = add i32 %32, %38
    %40 = sext i8 %37 to i16
    %41 = add i16 %34, %40
    %42 = trunc i32 %39 to i8
    %43 = xor i8 %36, %42
    %44 = add i32 %39, %30
    %45 = zext i16 %41 to i32
    %46 = xor i32 %44, %45
    %47 = zext i8 %43 to i32
    %48 = add i32 %46, %47
    %49 = getelementptr i8, ptr %29, i16 8
    %50 = add nsw i16 %28, -1
    %51 = icmp eq i16 %50, 0
    br i1 %51, label %24, label %27, !llvm.loop !17
  }
  
  ; Function Attrs: mustprogress nocallback nofree nounwind willreturn
  declare void @llvm.avm.debug.break() addrspace(1) #1
  
  attributes #0 = { nofree norecurse nounwind "no-builtins" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="avm1" "tune-cpu"="avm-interpreter-32u4-v1" }
  attributes #1 = { mustprogress nocallback nofree nounwind willreturn }
  
  !llvm.module.flags = !{!0}
  !llvm.ident = !{!1}
  !llvm.errno.tbaa = !{!2}
  
  !0 = !{i32 1, !"wchar_size", i32 2}
  !1 = !{!"clang version 22.1.8 (https://github.com/tiberiusbrown/llvm-project.git bfb537da7b0898514c500f193b67bbeaec224903)"}
  !2 = !{!3, !3, i64 0}
  !3 = !{!"int", !4, i64 0}
  !4 = !{!"omnipotent char", !5, i64 0}
  !5 = !{!"Simple C/C++ TBAA"}
  !6 = !{!7, !8, i64 0}
  !7 = !{!"", !8, i64 0, !3, i64 4, !4, i64 6, !4, i64 7}
  !8 = !{!"long", !4, i64 0}
  !9 = !{!7, !3, i64 4}
  !10 = !{!7, !4, i64 6}
  !11 = !{!7, !4, i64 7}
  !12 = distinct !{!12, !13}
  !13 = !{!"llvm.loop.mustprogress"}
  !14 = !{!8, !8, i64 0}
  !15 = distinct !{!15, !13}
  !16 = !{!4, !4, i64 0}
  !17 = distinct !{!17, !13}
...
---
