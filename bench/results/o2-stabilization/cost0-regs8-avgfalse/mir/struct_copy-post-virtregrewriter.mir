body:             |
  bb.0 (%ir-block.0):
    successors: %bb.2(0x80000000)
  
    $r2 = LDI8_PSEUDO 0
    $r3 = LDI8_PSEUDO 244
    $r0 = LDI8_PSEUDO 5
    $r1 = DATA_ADDR_PSEUDO @input_particles + 7
    $r4r5 = LDI32_PSEUDO 515, 1
    STACK_STORE32_PSEUDO %stack.1, 0, killed $r4r5 :: (store (s32) into %stack.1, align 1)
    $r4 = LDI8_PSEUDO 90
    STACK_STORE16_PSEUDO %stack.2, 0, killed $r4 :: (store (s16) into %stack.2, align 1)
    JMP_PSEUDO %bb.2
  
  bb.1 (%ir-block.1):
    successors: %bb.3(0x80000000)
  
    $r5 = LDI8_PSEUDO 0
    $r6r7 = LDI32_PSEUDO 0, 0
    SYS_DEBUG_BREAK_PSEUDO
    JMP_PSEUDO %bb.3
  
  bb.2 (%ir-block.2):
    successors: %bb.1(0x04000000), %bb.2(0x7c000000)
    liveins: $r0, $r1, $r2, $r3
  
    ADJCALLSTACKDOWN 0, 0, implicit-def dead $sp, implicit $sp
    $r4r5 = ZEXT16_32_PSEUDO $r2
    $r6r7 = STACK_LOAD32_PSEUDO %stack.1, 0 :: (load (s32) from %stack.1, align 1)
    CALL_DIRECT_PSEUDO &__avm_mulsi3, $r4r5, $r6r7, csr_avm_call, implicit-def $sp, implicit-def dead $cc, implicit $sp, implicit-def $r4r5
    ADJCALLSTACKUP 0, 0, implicit-def dead $sp, implicit $sp
    $r6r7 = LDI32_PSEUDO 0, 1
    $r6r7 = nuw nsw ADD32_PSEUDO killed $r6r7, killed $r4r5
    $r4 = COPY $r1
    $r4 = ADDIS8_PSEUDO killed $r4, -7
    STORE32_PSEUDO killed $r4, killed $r6r7 :: (store (s32) into %ir.10, align 1, !tbaa !6)
    $r4 = COPY $r3
    $r4 = ADDIS8_PSEUDO killed $r4, 12
    $r5 = STACK_LOAD16_PSEUDO %stack.2, 0 :: (load (s16) from %stack.2, align 1)
    $r4 = XOR16_PSEUDO killed $r4, killed $r5
    STORE8_DISP_PSEUDO $r1, -1, killed $r4 :: (store (s8) into %ir.14, !tbaa !10)
    STORE8_PSEUDO $r1, $r3 :: (store (s8) into %ir.3, !tbaa !11)
    STORE16_DISP_PSEUDO $r1, -3, $r0 :: (store (s16) into %ir.11, align 1, !tbaa !9)
    $r1 = ADDIS8_PSEUDO killed $r1, 8
    $r0 = nuw nsw ADDIS8_PSEUDO killed $r0, 73
    $r3 = INC16_PSEUDO killed $r3
    $r2 = nuw nsw INC16_PSEUDO killed $r2
    CMPIS8_PSEUDO $r2, 24, implicit-def $cc
    BR_CC_PSEUDO %bb.1, 0, implicit $cc
    JMP_PSEUDO %bb.2
  
  bb.3 (%ir-block.20):
    successors: %bb.6(0x80000000)
    liveins: $r5, $r6r7
  
    STACK_STORE16_PSEUDO %stack.0, 0, killed $r5 :: (store (s16) into %stack.0, align 1)
    $r3 = DATA_ADDR_PSEUDO @input_particles + 7
