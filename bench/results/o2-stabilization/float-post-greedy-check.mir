body:             |
  bb.0 (%ir-block.0):
    successors: %bb.2(0x80000000)
  
    %62:gpr32 = LDI32_PSEUDO 0, 0
    %97:gpr16 = DATA_ADDR_PSEUDO @input_b
    %100:gpr16 = DATA_ADDR_PSEUDO @input_a
    STACK_STORE16_PSEUDO %stack.5, 0, %100 :: (store (s16) into %stack.5, align 1)
    %102:gpr16 = LDI8_PSEUDO 16
    %103:gpr32 = LDI32_PSEUDO 0, 16000
    STACK_STORE32_PSEUDO %stack.7, 0, %103 :: (store (s32) into %stack.7, align 1)
    JMP_PSEUDO %bb.2
  
  bb.1 (%ir-block.1):
    successors: %bb.3(0x80000000)
  
    %78:gpr16 = LDI8_PSEUDO 0
    %90:gpr32 = LDI32_PSEUDO 0, 16128
    SYS_DEBUG_BREAK_PSEUDO
    JMP_PSEUDO %bb.3
  
  bb.2 (%ir-block.2):
    successors: %bb.1(0x04000000), %bb.2(0x7c000000)
  
    STACK_STORE16_PSEUDO %stack.6, 0, %102 :: (store (s16) into %stack.6, align 1)
    %28:gpr32 = COPY %62
    %104:gpr32 = STACK_LOAD32_PSEUDO %stack.7, 0 :: (load (s32) from %stack.7, align 1)
    %28:gpr32 = FMUL_PSEUDO %28, %104
    %96:gpr16 = COPY %97
    %27:gpr32 = LDI32_PSEUDO 0, -16448
    %28:gpr32 = FADD_PSEUDO %28, %27
    %99:gpr16 = STACK_LOAD16_PSEUDO %stack.5, 0 :: (load (s16) from %stack.5, align 1)
    STORE32_PSEUDO %99, %28 :: (volatile store (s32) into %ir.4, align 1, !tbaa !6)
    %29:gpr32 = LDI32_PSEUDO 0, 15872
    %32:gpr32 = COPY %62
    %32:gpr32 = FMUL_PSEUDO %32, %29
    %31:gpr32 = LDI32_PSEUDO 0, 16192
    %32:gpr32 = FADD_PSEUDO %32, %31
    STORE32_PSEUDO %96, %32 :: (volatile store (s32) into %ir.5, align 1, !tbaa !6)
    %97:gpr16 = COPY %96
    %71:gpr32 = nomerge LDI32_PSEUDO 0, 16256
    %62:gpr32 = FADD_PSEUDO %62, %71
    %102:gpr16 = STACK_LOAD16_PSEUDO %stack.6, 0 :: (load (s16) from %stack.6, align 1)
    %99:gpr16 = ADDIS8_PSEUDO %99, 4
    STACK_STORE16_PSEUDO %stack.5, 0, %99 :: (store (s16) into %stack.5, align 1)
    %97:gpr16 = ADDIS8_PSEUDO %97, 4
    %102:gpr16 = DEC16_PSEUDO %102
    TST8_PSEUDO %102, implicit-def $cc
    BR_CC_PSEUDO %bb.1, 0, implicit $cc
    JMP_PSEUDO %bb.2
  
  bb.3 (%ir-block.14):
    successors: %bb.6(0x80000000)
  
    STACK_STORE16_PSEUDO %stack.1, 0, %78 :: (store (s16) into %stack.1, align 1)
    %94:gpr32 = LDI32_PSEUDO 0, 0
    %81:gpr16 = DATA_ADDR_PSEUDO @input_b
    STACK_STORE16_PSEUDO %stack.2, 0, %81 :: (store (s16) into %stack.2, align 1)
    %83:gpr16 = DATA_ADDR_PSEUDO @input_a
    %86:gpr16 = LDI8_PSEUDO 16
    STACK_STORE32_PSEUDO %stack.4, 0, %94 :: (store (s32) into %stack.4, align 1)
    JMP_PSEUDO %bb.6
  
  bb.4 (%ir-block.17):
    %56:gpr16 = DATA_ADDR_PSEUDO @float_result
    %91:gpr32 = COPY %90
    STORE32_PSEUDO %56, %91 :: (volatile store (s32) into @float_result, align 1, !tbaa !6)
    %57:gpr16 = FTOS16_PSEUDO %91
    ABS_STORE16_PSEUDO @float_integer_result, %57 :: (volatile store (s16) into @float_integer_result, align 1, !tbaa !2)
    SYS_DEBUG_BREAK_PSEUDO
    %58:gpr16 = LDI8_PSEUDO 0
    $r4 = COPY %58
    RET_PSEUDO implicit-def dead $sp, implicit $sp, implicit $r4
  
  bb.5 (%ir-block.19):
    successors: %bb.4(0x04000000), %bb.3(0x7c000000)
  
    %78:gpr16 = STACK_LOAD16_PSEUDO %stack.1, 0 :: (load (s16) from %stack.1, align 1)
    %78:gpr16 = INC16_PSEUDO %78
    %55:gpr16 = COPY %78
    %55:gpr16 = ZEXT8_PSEUDO %55
